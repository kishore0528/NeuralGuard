# ═══════════════════════════════════════════════════════════
#  NeuralGuard IPS — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Usage: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpassword
POSTGRES_DB=neuralguard
POSTGRES_PORT=5432

# ── Grafana ───────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# ── IP Manager API ────────────────────────────────────────
API_PORT=5001

# ── IPS Thresholds ────────────────────────────────────────
THRESH_AUTO_BLOCK=0.90
THRESH_NEEDS_REVIEW=0.75

# ── Network ───────────────────────────────────────────────
# Comma-separated list of interfaces to sniff
SNIFF_INTERFACES=eno1,tailscale0
